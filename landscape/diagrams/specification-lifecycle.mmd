%% Specification Lifecycle
%% Shows how artifacts flow from discovery to implementation

flowchart LR
    subgraph Discovery["1. Discovery (Elara)"]
        PROC[Processes<br/>Actors<br/>Rules]
        FEAT_C[Feature<br/>Candidates]
        PERS[Personas]
        PROC --> FEAT_C
    end

    subgraph Freeze["2. Freeze"]
        CF[Conceptual<br/>Freeze<br/>Artifact]
    end

    subgraph Specification["3. Specification (Telos)"]
        SUITE_S[Suite Spec<br/>.md]
        SVC_S[Service Spec<br/>.md]
        FEAT_S["Feature Spec<br/>F-{SUITE}-NNN.md"]
        WF_S["Workflow Spec<br/>wf-{name}"]
        SUITE_S --> SVC_S
        SUITE_S --> FEAT_S
        SUITE_S --> WF_S
    end

    subgraph Contracts["4. Contracts"]
        OA[OpenAPI<br/>.yaml]
        EV[Event Schema<br/>.schema.json]
        UVL_F["Feature UVL<br/>F-{SUITE}-NNN.uvl"]
    end

    subgraph Implementation["5. Implementation"]
        BE[Backend Service<br/>Java 25 / Spring Boot 4]
        FE[Product UI<br/>Nuxt 4 / Vue 3]
    end

    subgraph Validation["6. Validation"]
        CDC[Contract Tests<br/>CDC]
        ARCH[ArchUnit Tests]
        ONT[Ontology<br/>Compliance]
    end

    PROC --> CF
    FEAT_C --> CF
    PERS --> CF
    CF --> SUITE_S
    CF --> FEAT_S

    SVC_S --> OA & EV
    FEAT_S --> UVL_F

    OA --> BE
    EV --> BE
    UVL_F --> FE

    BE --> CDC & ARCH
    FE --> ONT

    classDef elara fill:#e3f2fd,stroke:#1565c0
    classDef telos fill:#e8f5e9,stroke:#2e7d32
    classDef contract fill:#fff3e0,stroke:#e65100
    classDef impl fill:#f3e5f5,stroke:#6a1b9a
    classDef valid fill:#fce4ec,stroke:#880e4f

    class PROC,FEAT_C,PERS,CF elara
    class SUITE_S,SVC_S,FEAT_S,WF_S telos
    class OA,EV,UVL_F contract
    class BE,FE impl
    class CDC,ARCH,ONT valid
